{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "build",
			"command": "C:\\mingw64\\bin\\gcc.exe",
			"args": [
				"-g",
				"${workspaceFolder}\\*.c",
				"-o",
				"${fileDirname}\\main.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "compiler: C:\\mingw64\\bin\\gcc.exe"
		},
		{
			"type": "cppbuild",
			"label": "build",
			"command": "C:\\mingw64\\bin\\clang++.exe",
			"args": [
				"-g",
				"${workspaceFolder}\\*.c",
				"-o",
				"${fileDirname}\\main.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "compiler: C:\\mingw64\\bin\\clang++.exe"
		}
	]
}